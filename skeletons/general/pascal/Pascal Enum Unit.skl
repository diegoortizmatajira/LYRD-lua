return function (buf)
	local text = require("LYRD.layers.text")
	local name = vim.api.nvim_buf_get_name(buf)
	local basename = vim.fs.basename(name)
	local file_stem = basename:match("(.+)%..+$")
	local type_name = text.to_pascal_case(file_stem)

	return {
		unit_name = type_name,
		type_name = type_name,
		_cursor = { 8, 9 }
	}
end
---
unit ${unit_name};

interface

type
    ${type_name} = (
        Unknown
    );

implementation

end.


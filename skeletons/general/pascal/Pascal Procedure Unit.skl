return function (buf)
	local text = require("LYRD.layers.text")
	local name = vim.api.nvim_buf_get_name(buf)
	local basename = vim.fs.basename(name)
	local file_stem = basename:match("(.+)%..+$")
	local pascal_name = text.to_pascal_case(file_stem)

	return {
		unit_name = pascal_name,
		procedure_name = pascal_name,
		_cursor = { 10, 1 }
	}
end
---
unit ${unit_name};

interface

procedure ${procedure_name};

implementation

procedure ${procedure_name};
begin
end;

end.


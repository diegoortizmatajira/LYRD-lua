return function (buf)
    local generator = require("LYRD.layers.lang.dotnet-generator")
  local name = vim.api.nvim_buf_get_name(buf)
  local basename = vim.fs.basename(name)
  basename = basename:match("(.+)%..+$")
  request = string.gsub(basename, "Handler", "Request")

  return { 
      type_name = basename,
      request_type_name = request,
      namespace = generator.get_namespace(name),
      _cursor = { 6, 5 }
    }
end
---
using MediatR;
using Microsoft.Extensions.Logging;
using Scrutor;

namespace ${namespace};

[ServiceDescriptor]
public class ${type_name}(
    ILogger<${type_name}> logger
) 
: IRequestHandler<${request_type_name}>
{
    public Task Handle(${request_type_name} request, CancellationToken cancellationToken)
    {
        throw new NotImplementedException();
    }
}

return function (buf)
	local text = require("LYRD.layers.text")
	local name = vim.api.nvim_buf_get_name(buf)
	local basename = vim.fs.basename(name)
	local file_stem = basename:match("(.+)%..+$")
	file_stem = file_stem:gsub("_it$", "")

	return {
		test_name = text.to_snake_case(file_stem),
		_cursor = { 5, 5 }
	}
end
---
#[test]
fn ${test_name}_integration_works() {
	assert!(true);
}

